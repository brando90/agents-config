{
  "model": "claude-fable-5[1m]",
  "effortLevel": "max",
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/agents-config/scripts/auto-update-tools.sh",
            "timeout": 60,
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/agents-config/scripts/refresh-agents-config.sh",
            "timeout": 20,
            "statusMessage": "Refreshing agents-config"
          }
        ]
      }
    ]
  }
}
